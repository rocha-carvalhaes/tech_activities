# Firebase (Cloud Firestore) — ranking compartilhado da atividade Personagem Saltador.
# Copie este arquivo para `.env` e preencha com a config web do seu projeto Firebase
# (Console do Firebase -> Configuracoes do projeto -> Seus apps -> SDK web).
# Sem essas variaveis, o jogo funciona normalmente, mas o ranking fica indisponivel.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
